#!/usr/bin/env bash
set -euo pipefail

# ── Config ────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
XDG_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/git-seed/repos.conf"

if [[ -n "${CONF_FILE:-}" ]]; then
    CONF="$CONF_FILE"
elif [[ -f "$XDG_CONF" ]]; then
    CONF="$XDG_CONF"
else
    CONF="$SCRIPT_DIR/repos.conf"
fi

BASE_DIR="${BASE_DIR:-$HOME/git-seed-repos}"
DRY_RUN=false
CLONE_ONLY=false
PULL_ONLY=false

# ── Auth ──────────────────────────────────────────────────────────
_TOKEN=""

get_token() {
    if [[ "$_TOKEN" == "__none__" ]]; then
        return
    fi
    if [[ -n "$_TOKEN" ]]; then
        echo "$_TOKEN"
        return
    fi
    if [[ -n "${GITHUB_TOKEN:-}" ]]; then
        _TOKEN="$GITHUB_TOKEN"
    elif command -v gh &>/dev/null; then
        _TOKEN="$(gh auth token 2>/dev/null || true)"
    fi
    if [[ -z "$_TOKEN" ]]; then
        _TOKEN="__none__"
        return
    fi
    echo "$_TOKEN"
}

# ── Parse conf ────────────────────────────────────────────────────
# Calls: callback base_dir dir owner/repo
# Handles [path] sections, skips comments and blank lines,
# warns on malformed entries. Entries above any [path] section
# use BASE_DIR as fallback.
parse_conf() {
    local callback="$1"
    local current_base="$BASE_DIR"

    if [[ ! -f "$CONF" ]]; then
        echo "[ERROR] Config file not found: $CONF" >&2
        exit 1
    fi

    while IFS= read -r line; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// }" ]]           && continue

        if [[ "$line" =~ ^\[path[[:space:]]+(.+)\]$ ]]; then
            current_base="${BASH_REMATCH[1]/#\~/$HOME}"
            continue
        fi

        local dir repo
        read -r dir repo <<< "$line"
        [[ -z "$dir" || -z "$repo" ]] && continue

        if [[ "$repo" != */* ]]; then
            echo "[WARN]  Skipping malformed entry: $line" >&2
            continue
        fi

        "$callback" "$current_base" "$dir" "$repo" || true
    done < "$CONF"
}

# ── Collect unique [path] entries from conf ───────────────────────
# Only includes BASE_DIR if there are entries above any [path] section.
get_conf_paths() {
    local -n _out="$1"

    [[ ! -f "$CONF" ]] && _out["$BASE_DIR"]=1 && return

    local seen_path_section=false
    local has_pre_section_entries=false

    while IFS= read -r line; do
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// }" ]]           && continue

        if [[ "$line" =~ ^\[path[[:space:]]+(.+)\]$ ]]; then
            seen_path_section=true
            local p="${BASH_REMATCH[1]/#\~/$HOME}"
            _out["$p"]=1
        elif [[ "$seen_path_section" == false ]]; then
            has_pre_section_entries=true
        fi
    done < "$CONF"

    if [[ "$seen_path_section" == false || "$has_pre_section_entries" == true ]]; then
        _out["$BASE_DIR"]=1
    fi
}

# ── Sync callback (clone missing, pull existing) ──────────────────
do_sync() {
    local base_dir="$1" dir="$2" repo="$3"
    local dest="$base_dir/$dir/$(basename "$repo")"

    if [[ -d "$dest" ]]; then
        if [[ "$CLONE_ONLY" == true ]]; then
            echo "[SKIP]  $repo (already exists)"
            return
        fi
        if [[ "$DRY_RUN" == true ]]; then
            echo "[DRY]   would pull $repo"
        else
            echo "[PULL]  $repo"
            git -C "$dest" pull || { echo "[ERROR] Failed to pull $repo"; return 1; }
        fi
        return
    fi

    if [[ "$PULL_ONLY" == true ]]; then
        echo "[SKIP]  $repo (not cloned)"
        return
    fi

    if [[ "$DRY_RUN" == true ]]; then
        echo "[DRY]   would clone $repo → $dest"
        return
    fi

    local token
    token="$(get_token)"
    local url="https://github.com/${repo}.git"
    mkdir -p "$base_dir/$dir"
    echo "[CLONE] $repo → $dest"

    if [[ -n "$token" ]]; then
        git -c "credential.helper=!f() { echo username=x-access-token; echo password=$token; }; f" \
            clone "$url" "$dest" || { echo "[ERROR] Failed to clone $repo"; return 1; }
    else
        git clone "$url" "$dest" || { echo "[ERROR] Failed to clone $repo"; return 1; }
    fi
}

# ── Status callback ───────────────────────────────────────────────
STATUS_CLONED=0
STATUS_MISSING=0
STATUS_DIRTY=0

do_status() {
    local base_dir="$1" dir="$2" repo="$3"
    local dest="$base_dir/$dir/$(basename "$repo")"

    if [[ ! -d "$dest" ]]; then
        printf "[MISSING] %s\n" "$repo"
        STATUS_MISSING=$((STATUS_MISSING + 1))
    elif ! git -C "$dest" diff --quiet 2>/dev/null || \
         ! git -C "$dest" diff --cached --quiet 2>/dev/null; then
        printf "[DIRTY]   %s\n" "$repo"
        STATUS_DIRTY=$((STATUS_DIRTY + 1))
        STATUS_CLONED=$((STATUS_CLONED + 1))
    else
        printf "[OK]      %s\n" "$repo"
        STATUS_CLONED=$((STATUS_CLONED + 1))
    fi
}

# ── Emit callback + shared helpers for frontend commands ──────────
# Emits one TAB-separated "owner/repo<TAB>path" per manifest entry.
do_emit() {
    local base_dir="$1" dir="$2" repo="$3"
    printf "%s\t%s/%s/%s\n" "$repo" "$base_dir" "$dir" "$(basename "$repo")"
}

# Emit only entries whose local clone exists.
emit_existing() {
    parse_conf do_emit | while IFS=$'\t' read -r r p; do
        if [[ -d "$p" ]]; then printf "%s\t%s\n" "$r" "$p"; fi
    done
}

is_dirty() {
    local path="$1"
    [[ -n "$(git -C "$path" status --porcelain 2>/dev/null)" ]]
}

# ── Picker shared by --browse / --open ───────────────────────────
# Reads "label<TAB>path" lines on stdin, prints the chosen path to stdout.
# Uses fzf if present, otherwise a numbered prompt.
# $1: fzf preview command (empty string disables preview).
pick_select() {
    local preview="$1"
    local lines
    lines="$(cat)"
    if [[ -z "$lines" ]]; then
        echo "[ERROR] No tracked, cloned repos in manifest." >&2
        return 1
    fi

    local selected=""
    if command -v fzf &>/dev/null; then
        if [[ -n "$preview" ]]; then
            selected="$(printf "%s\n" "$lines" \
                | fzf --delimiter=$'\t' --with-nth=1 \
                      --preview "$preview" \
                      --preview-window='right,60%,wrap')" || return 1
        else
            selected="$(printf "%s\n" "$lines" \
                | fzf --delimiter=$'\t' --with-nth=1)" || return 1
        fi
    else
        local -a arr=()
        while IFS= read -r _line; do
            arr+=("$_line")
        done <<< "$lines"
        local i=1
        for entry in "${arr[@]}"; do
            local label="${entry%%$'\t'*}"
            printf "  %d) %s\n" "$i" "$label" >&2
            i=$((i+1))
        done
        printf "  Choose [1-%d]: " "${#arr[@]}" >&2
        local n
        read -r n </dev/tty || return 1
        [[ -z "$n" ]] && return 1
        [[ "$n" =~ ^[0-9]+$ ]] || return 1
        (( n >= 1 && n <= ${#arr[@]} )) || return 1
        selected="${arr[$((n-1))]}"
    fi

    [[ -z "$selected" ]] && return 1
    printf "%s\n" "$selected" | cut -f2
}

# ── --browse ──────────────────────────────────────────────────────
browse_preview_cmd() {
    cat <<'EOF'
path={2}
echo "Repo:   {1}"
echo "Path:   $path"
echo "Remote: $(git -C "$path" remote get-url origin 2>/dev/null)"
echo
status=$(git -C "$path" status --porcelain 2>/dev/null)
if [ -n "$status" ]; then
    n=$(printf "%s\n" "$status" | wc -l | tr -d ' ')
    echo "Status: dirty ($n changes)"
    printf "%s\n" "$status" | head -5 | sed 's/^/  /'
else
    echo "Status: clean"
fi
echo
echo "Recent commits:"
git -C "$path" log --oneline -10 2>/dev/null
echo
if [ -f "$path/README.md" ]; then
    echo "README:"
    head -20 "$path/README.md"
fi
EOF
}

browse_repos() {
    if ! command -v fzf &>/dev/null; then
        echo "[WARN]  fzf not found; --browse degrades to a numbered list" >&2
    fi
    emit_existing | pick_select "$(browse_preview_cmd)"
}

# ── --where ───────────────────────────────────────────────────────
where_repo() {
    local target="$1"

    # Exact owner/repo match wins.
    while IFS=$'\t' read -r repo path; do
        if [[ "$repo" == "$target" ]]; then
            printf "%s\n" "$path"
            return 0
        fi
    done < <(parse_conf do_emit)

    # Fall back to basename match (e.g. "intermcli" -> "pdbeard/intermcli").
    while IFS=$'\t' read -r repo path; do
        if [[ "$(basename "$repo")" == "$target" ]]; then
            printf "%s\n" "$path"
            return 0
        fi
    done < <(parse_conf do_emit)

    echo "[ERROR] No manifest entry matches: $target" >&2
    return 1
}

# ── --recent ──────────────────────────────────────────────────────
recent_repos() {
    local n="$1"
    emit_existing | while IFS=$'\t' read -r r p; do
        local ts
        ts="$(git -C "$p" log -1 --format=%ct 2>/dev/null || true)"
        [[ -z "$ts" ]] && ts=0
        printf "%s\t%s\n" "$ts" "$p"
    done | sort -rn | head -n "$n" | cut -f2
}

# ── --dirty ───────────────────────────────────────────────────────
dirty_repos() {
    emit_existing | while IFS=$'\t' read -r r p; do
        if is_dirty "$p"; then printf "%s\n" "$p"; fi
    done
}

# ── --open ────────────────────────────────────────────────────────
open_repo() {
    local editor="$1"
    if [[ -z "$editor" ]]; then
        editor="${EDITOR:-}"
    fi
    if [[ -z "$editor" ]]; then
        for e in code vim; do
            if command -v "$e" &>/dev/null; then editor="$e"; break; fi
        done
    fi
    if [[ -z "$editor" ]]; then
        echo "[ERROR] No editor found (\$EDITOR unset, code/vim not on PATH)" >&2
        exit 1
    fi

    local path
    path="$(browse_repos)" || exit 1
    [[ -z "$path" ]] && exit 1
    exec "$editor" "$path"
}

# ── Scout: insert helper ──────────────────────────────────────────
# Adds "$dir  $owner_repo" under the matching [path "$search_dir"] section,
# or appends a fresh section if one isn't there yet.
scout_insert_entry() {
    local search_dir="$1" dir="$2" owner_repo="$3"

    local section_header_tilde="[path ${search_dir/#$HOME/\~}]"
    local section_header_full="[path $search_dir]"
    local section_header=""
    if grep -qF "$section_header_tilde" "$CONF" 2>/dev/null; then
        section_header="$section_header_tilde"
    elif grep -qF "$section_header_full" "$CONF" 2>/dev/null; then
        section_header="$section_header_full"
    fi

    if [[ -n "$section_header" ]]; then
        local tmp
        tmp="$(mktemp)"
        awk -v hdr="$section_header" -v entry="$dir  $owner_repo" '
            BEGIN { in_section=0; last_entry_line=0; header_line=0 }
            $0 == hdr { in_section=1; header_line=NR }
            in_section && /^\[path / && $0 != hdr { in_section=0 }
            in_section && /^[^#\[]/ && NF { last_entry_line=NR }
            { lines[NR]=$0 }
            END {
                insert_after = (last_entry_line > 0) ? last_entry_line : header_line
                for (i=1; i<=NR; i++) {
                    print lines[i]
                    if (i==insert_after) print entry
                }
            }
        ' "$CONF" > "$tmp" && mv "$tmp" "$CONF" || { rm -f "$tmp"; return 1; }
    else
        printf "\n%s\n%s\n" "$section_header_tilde" "$dir  $owner_repo" >> "$CONF"
    fi
    return 0
}

# ── Scout: collect untracked candidates ───────────────────────────
# Emits one TAB-separated row per candidate:
#   owner/repo<TAB>dir<TAB>search_dir<TAB>repo_path<TAB>remote
scout_collect_candidates() {
    declare -A search_paths
    get_conf_paths search_paths

    declare -A known
    if [[ -f "$CONF" ]]; then
        while IFS= read -r line; do
            local stripped="${line#\#}"
            stripped="${stripped#"${stripped%%[! ]*}"}"
            [[ "$stripped" =~ ^\[path ]] && continue
            local _ repo
            read -r _ repo <<< "$stripped"
            [[ -n "$repo" && "$repo" == */* ]] && known["$repo"]=1
        done < "$CONF"
    fi

    for search_dir in "${!search_paths[@]}"; do
        [[ ! -d "$search_dir" ]] && continue

        while IFS= read -r gitdir; do
            local repo_path="${gitdir%/.git}"
            local rel_path="${repo_path#"$search_dir"/}"

            local dir folder_name
            folder_name="${rel_path##*/}"
            if [[ "$rel_path" == */* ]]; then
                dir="${rel_path%/*}"
            else
                dir=""
            fi

            local remote owner_repo
            remote=$(git -C "$repo_path" remote get-url origin 2>/dev/null || true)
            if [[ "$remote" =~ github\.com[:/]([^/]+/[^/.]+)(\.git)?$ ]]; then
                owner_repo="${BASH_REMATCH[1]}"
            else
                owner_repo="$folder_name"
            fi

            [[ -n "${known[$owner_repo]:-}" ]] && continue
            [[ -z "$dir" ]] && continue

            printf "%s\t%s\t%s\t%s\t%s\n" \
                "$owner_repo" "$dir" "$search_dir" "$repo_path" "$remote"
        done < <(find "$search_dir" -name ".git" -type d -prune 2>/dev/null | sort)
    done
}

# ── Scout: dispatcher (fzf if present, else interactive prompt) ───
scout_repos() {
    local candidates
    candidates="$(scout_collect_candidates)"

    if [[ -z "$candidates" ]]; then
        echo "[OK] All repos are already tracked in repos.conf."
        return 0
    fi

    if command -v fzf &>/dev/null; then
        scout_fzf "$candidates"
    else
        scout_prompt "$candidates"
    fi
}

scout_fzf() {
    local candidates="$1"
    local total
    total="$(printf "%s\n" "$candidates" | wc -l | tr -d ' ')"
    echo "[INFO] Found $total untracked repo(s). TAB to multi-select, ENTER to add." >&2

    local preview
    preview='
path={4}
echo "Repo:    {1}"
echo "Dir:     {2}"
echo "Section: {3}"
echo "Path:    $path"
echo "Remote:  {5}"
echo
echo "Recent commits:"
git -C "$path" log --oneline -5 2>/dev/null
echo
if [ -f "$path/README.md" ]; then
    echo "README:"
    head -15 "$path/README.md"
fi
'

    local selected
    if ! selected="$(printf "%s\n" "$candidates" \
        | fzf --multi --delimiter=$'\t' --with-nth=1,2 \
              --preview "$preview" --preview-window='right,60%,wrap' \
              --header='TAB: select  ENTER: add selected to repos.conf')"; then
        echo "[OK] No candidates selected."
        return 0
    fi
    [[ -z "$selected" ]] && { echo "[OK] No candidates selected."; return 0; }

    local added=0
    while IFS=$'\t' read -r owner_repo dir search_dir repo_path remote; do
        [[ -z "$owner_repo" ]] && continue
        if scout_insert_entry "$search_dir" "$dir" "$owner_repo"; then
            echo "[ADDED] $dir  $owner_repo"
            added=$((added + 1))
        else
            echo "[ERROR] Failed to add $owner_repo" >&2
        fi
    done <<< "$selected"

    echo ""
    if [[ "$added" -eq 0 ]]; then
        echo "[OK] $total untracked repo(s) found, none added."
    else
        echo "[DONE] Added $added of $total untracked repo(s) to repos.conf."
        echo "[HINT] Try: git-seed --browse"
    fi
}

scout_prompt() {
    local candidates="$1"
    local found=0 added=0

    while IFS=$'\t' read -r owner_repo dir search_dir repo_path remote; do
        found=$((found + 1))
        echo ""
        echo "  Found:  $owner_repo"
        echo "  Path:   $repo_path"
        [[ -n "$remote" ]] && echo "  Remote: $remote"

        printf "  Add to repos.conf under '%s'? [y/N] " "$dir"
        local answer; read -r answer </dev/tty
        [[ ! "$answer" =~ ^[Yy]$ ]] && continue

        if scout_insert_entry "$search_dir" "$dir" "$owner_repo"; then
            echo "  [ADDED] $dir  $owner_repo"
            added=$((added + 1))
        else
            echo "  [ERROR] Failed to update conf" >&2
        fi
    done <<< "$candidates"

    echo ""
    if [[ "$added" -eq 0 ]]; then
        echo "[OK] $found untracked repo(s) found, none added."
    else
        echo "[DONE] Added $added of $found untracked repo(s) to repos.conf."
        echo "[HINT] Try: git-seed --browse"
    fi
}

# ── List repos via gh ─────────────────────────────────────────────
list_repos() {
    if ! command -v gh &>/dev/null; then
        echo "[ERROR] 'gh' CLI required for --list. Run: gh auth login" >&2
        exit 1
    fi
    echo "# Paste into repos.conf:"
    gh repo list --limit 200 --json nameWithOwner --jq '.[].nameWithOwner' | \
        awk '{ print "projects  " $0 }'
}

# ── Usage ─────────────────────────────────────────────────────────
usage() {
    cat <<EOF
Usage: git-seed <command> [options]

Manifest commands:
  --sync           Clone missing repos and pull existing ones
  --clone-only     Clone missing repos, skip existing
  --pull-only      Pull existing repos, skip missing
  --scout          Scan paths defined in conf for untracked git repos and
                   interactively offer to add them (multi-select fzf if present)
  --status         Show cloned/missing/dirty state for all repos in conf
  --list           List your GitHub repos via gh CLI (requires gh auth login)
                   Outputs lines ready to paste into repos.conf

Frontend commands:
  --browse         fzf picker with preview (commits, status, README).
                   Prints selected path on stdout.
  --where <repo>   Look up the local path for owner/repo (or basename).
                   Prints path on stdout.
  --recent [N]     List N most-recently-committed tracked repos (default 20).
                   One path per line.
  --dirty          List tracked repos with uncommitted changes.
                   One path per line.
  --open [editor]  Run --browse, then open the selection in editor.
                   Editor defaults: \$EDITOR, then code, then vim.

Options:
  --dry-run        Print what would happen without making any changes
                   (works with --sync, --clone-only, --pull-only)
  --conf FILE      Use a specific config file
  --base DIR       Fallback base dir for entries with no [path] section
                   (default: ~/git-seed-repos)
  --help           Show this message

Composition examples:
  cd "\$(git-seed --browse)"
  \$EDITOR "\$(git-seed --where pdbeard/intermcli)"
  git-seed --dirty | xargs -I{} git -C {} status -s
  git-seed --recent 5

Config file lookup order:
  1. --conf FILE
  2. ~/.config/git-seed/repos.conf  (or \$XDG_CONFIG_HOME/git-seed/repos.conf)
  3. <script dir>/repos.conf

Config format (repos.conf):
  [path ~/projects]
  personal      youruser/your-repo
  work          yourorg/their-repo

  [path ~/src]
  libs          someuser/a-library
EOF
}

# ── Main ──────────────────────────────────────────────────────────
[[ $# -eq 0 ]] && usage && exit 0

COMMAND=""
WHERE_REPO=""
RECENT_N=20
OPEN_EDITOR=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --sync)        COMMAND="sync" ;;
        --clone-only)  COMMAND="clone-only" ;;
        --pull-only)   COMMAND="pull-only" ;;
        --scout)       COMMAND="scout" ;;
        --status)      COMMAND="status" ;;
        --list)        COMMAND="list" ;;
        --browse)      COMMAND="browse" ;;
        --where)       [[ -z "${2:-}" || "${2:-}" == --* ]] && { echo "[ERROR] --where requires a repo argument" >&2; exit 1; }
                       COMMAND="where"; WHERE_REPO="$2"; shift ;;
        --where=*)     COMMAND="where"; WHERE_REPO="${1#--where=}"
                       [[ -z "$WHERE_REPO" ]] && { echo "[ERROR] --where requires a repo argument" >&2; exit 1; } ;;
        --recent)      COMMAND="recent"
                       if [[ -n "${2:-}" && "${2:-}" != --* ]]; then
                           [[ "$2" =~ ^[0-9]+$ ]] || { echo "[ERROR] --recent expects a positive integer, got: $2" >&2; exit 1; }
                           RECENT_N="$2"; shift
                       fi ;;
        --dirty)       COMMAND="dirty" ;;
        --open)        COMMAND="open"
                       if [[ -n "${2:-}" && "${2:-}" != --* ]]; then
                           OPEN_EDITOR="$2"; shift
                       fi ;;
        --dry-run)     DRY_RUN=true ;;
        --conf)        [[ -z "${2:-}" || "${2:-}" == --* ]] && { echo "[ERROR] --conf requires a file argument" >&2; exit 1; }
                       CONF="$2"; shift ;;
        --conf=*)      CONF="${1#--conf=}"; [[ -z "$CONF" ]] && { echo "[ERROR] --conf requires a file argument" >&2; exit 1; } ;;
        --base)        BASE_DIR="$2"; shift ;;
        --base=*)      BASE_DIR="${1#--base=}" ;;
        --help)        usage; exit 0 ;;
        *)             echo "[ERROR] Unknown option: $1" >&2; usage; exit 1 ;;
    esac
    shift
done

[[ -z "$COMMAND" ]] && usage && exit 0

case "$COMMAND" in
    sync)        parse_conf do_sync ;;
    clone-only)  CLONE_ONLY=true;  parse_conf do_sync ;;
    pull-only)   PULL_ONLY=true;   parse_conf do_sync ;;
    scout)       scout_repos ;;
    status)      parse_conf do_status
                 echo ""
                 echo "  cloned: $STATUS_CLONED  missing: $STATUS_MISSING  dirty: $STATUS_DIRTY" ;;
    list)        list_repos ;;
    browse)      browse_repos ;;
    where)       where_repo "$WHERE_REPO" ;;
    recent)      recent_repos "$RECENT_N" ;;
    dirty)       dirty_repos ;;
    open)        open_repo "$OPEN_EDITOR" ;;
esac
